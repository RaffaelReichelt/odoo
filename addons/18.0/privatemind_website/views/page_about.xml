<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="page_about" name="PrivateMind About">
        <t t-call="website.layout">
            <t t-set="additional_title">About PrivateMind</t>
            <t t-set="meta_description">PrivateMind GmbH — Based in Dresden, Germany. We build local AI infrastructure for European SMEs who can't send their data to the cloud.</t>

            <div id="wrap">

                <!-- Hero -->
                <section class="pm-about-hero">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <h1>AI for Europe.<br/>Built in Germany.</h1>
                                <p class="mt-4">
                                    We believe European businesses deserve AI that respects their data, their laws,
                                    and their independence. PrivateMind was founded to fill the gap that no one else is filling:
                                    powerful, private AI that any SME can actually operate.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Mission -->
                <section class="pm-section" style="background:#fff;">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-6">
                                <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:#111;margin-bottom:20px;">
                                    The Market Gap We're Filling
                                </h2>
                                <p style="color:#4a5d73;line-height:1.75;margin-bottom:16px;">
                                    European SMEs face a paradox: AI has become a competitive necessity,
                                    but the dominant cloud AI tools — ChatGPT, Copilot, Gemini — require sending
                                    sensitive data to US servers. For law firms, medical practices, tax advisors,
                                    and financial service providers, this isn't a grey area. It's a legal problem.
                                </p>
                                <p style="color:#4a5d73;line-height:1.75;margin-bottom:16px;">
                                    Self-hosting open-source models is technically possible — but it requires
                                    Linux expertise, GPU driver management, Docker orchestration, and ongoing
                                    maintenance that simply doesn't exist in most SMEs.
                                </p>
                                <p style="color:#4a5d73;line-height:1.75;">
                                    <strong style="color:#111;">PrivateMind closes this gap.</strong> We deliver a complete,
                                    managed AI system — hardware, software, models, support — in a single package
                                    that any business can operate, regardless of IT expertise.
                                </p>
                            </div>
                            <div class="col-lg-6">
                                <div class="row g-3">
                                    <div class="col-6">
                                        <div class="pm-values-card">
                                            <div style="font-size:1.8rem;margin-bottom:12px;">🔒</div>
                                            <h5>Data Sovereignty</h5>
                                            <p>Your data stays in your building. Every inference, every query, every document — processed locally.</p>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="pm-values-card">
                                            <div style="font-size:1.8rem;margin-bottom:12px;">🎯</div>
                                            <h5>Zero Expertise Needed</h5>
                                            <p>Plug in, switch on. We handle all the technical complexity. You focus on your work.</p>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="pm-values-card">
                                            <div style="font-size:1.8rem;margin-bottom:12px;">🇪🇺</div>
                                            <h5>European Values</h5>
                                            <p>GDPR, EU AI Act, NIS2 — we treat European data law as a design principle, not a marketing claim.</p>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="pm-values-card">
                                            <div style="font-size:1.8rem;margin-bottom:12px;">⚡</div>
                                            <h5>Enterprise Performance</h5>
                                            <p>NVIDIA GB10 Grace Blackwell — the same GPU architecture used in data centres, now on your desk.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Founder -->
                <section class="pm-section" style="background:#f8fafc;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <h2 class="pm-section-title">The Founder</h2>
                                <div class="pm-contact-card mt-4">
                                    <div class="row align-items-center g-4">
                                        <div class="col-auto">
                                            <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#00d4ff,#007bff,#8b2af8);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:#fff;">
                                                R
                                            </div>
                                        </div>
                                        <div class="col">
                                            <h4 style="font-weight:700;margin-bottom:4px;">Raffael Reichelt</h4>
                                            <p style="color:#007bff;font-size:0.9rem;margin-bottom:0;">Founder &amp; CEO, PrivateMind GmbH</p>
                                        </div>
                                    </div>
                                    <hr style="margin:24px 0;border-color:#e2e8f0;"/>
                                    <p style="color:#4a5d73;line-height:1.75;margin-bottom:14px;">
                                        Raffael is a software developer with decades of hands-on experience in enterprise IT.
                                        Having worked across industries where data confidentiality is non-negotiable, he saw
                                        first-hand how AI adoption was blocked not by willingness, but by the absence of a
                                        suitable, compliant option.
                                    </p>
                                    <p style="color:#4a5d73;line-height:1.75;margin-bottom:0;">
                                        PrivateMind is his answer: a productised, managed AI service built on the latest
                                        NVIDIA hardware — designed specifically for the SMEs that cloud AI vendors systematically
                                        ignore.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Why Now -->
                <section class="pm-section" style="background:#fff;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8 text-center">
                                <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:#111;margin-bottom:20px;">
                                    Why Now Is the Right Moment
                                </h2>
                            </div>
                        </div>
                        <div class="row g-4 mt-2">
                            <div class="col-md-4">
                                <div class="pm-problem-card">
                                    <div class="pm-icon">🖥️</div>
                                    <h4>The Hardware Breakthrough</h4>
                                    <p>
                                        The NVIDIA GB10 Grace Blackwell is the first chip to bring data-centre-grade
                                        AI inference to desktop form factor. What required a rack 18 months ago
                                        now fits in a 15×15×5 cm box consuming 240W.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="pm-problem-card">
                                    <div class="pm-icon">📜</div>
                                    <h4>Regulatory Pressure</h4>
                                    <p>
                                        The EU AI Act (August 2024), record GDPR fines (€1.6B in 2024),
                                        and DORA/NIS2 compliance requirements are pushing data-sensitive businesses
                                        to look for local alternatives — now.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="pm-problem-card">
                                    <div class="pm-icon">🌐</div>
                                    <h4>Geopolitical Risk Is Real</h4>
                                    <p>
                                        In June 2026, US export controls cut off access to leading AI models overnight
                                        for European users — without warning or transition period.
                                        Local AI is not just a privacy argument anymore. It's infrastructure sovereignty.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Location -->
                <section class="pm-section" style="background:#f8fafc;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-7 text-center">
                                <h2 style="font-size:1.8rem;font-weight:700;color:#111;margin-bottom:16px;">
                                    📍 Based in Dresden, Germany
                                </h2>
                                <p style="color:#4a5d73;line-height:1.75;">
                                    PrivateMind GmbH (in Gründung) is headquartered in Dresden, Saxony —
                                    in the heart of one of Germany's fastest-growing tech ecosystems.
                                    We serve customers across the DACH region with plans for expansion
                                    into the Netherlands, Nordics, and UK.
                                </p>
                                <div class="d-flex justify-content-center gap-4 mt-4 flex-wrap">
                                    <span class="badge" style="background:#f0f4f8;color:#4a5d73;font-size:0.85rem;font-weight:500;padding:8px 16px;border-radius:6px;">
                                        🇩🇪 Germany
                                    </span>
                                    <span class="badge" style="background:#f0f4f8;color:#4a5d73;font-size:0.85rem;font-weight:500;padding:8px 16px;border-radius:6px;">
                                        🇦🇹 Austria
                                    </span>
                                    <span class="badge" style="background:#f0f4f8;color:#4a5d73;font-size:0.85rem;font-weight:500;padding:8px 16px;border-radius:6px;">
                                        🇨🇭 Switzerland
                                    </span>
                                    <span class="badge" style="background:#f0f4f8;color:#4a5d73;font-size:0.85rem;font-weight:500;padding:8px 16px;border-radius:6px;">
                                        🇳🇱 Netherlands
                                    </span>
                                    <span class="badge" style="background:#f0f4f8;color:#4a5d73;font-size:0.85rem;font-weight:500;padding:8px 16px;border-radius:6px;">
                                        🇬🇧 United Kingdom
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- CTA -->
                <section class="pm-cta-section">
                    <div class="container position-relative">
                        <h2>Join the First Wave</h2>
                        <p>We're working with our first pilot customers in DACH. Get in touch to see what local AI can do for your business.</p>
                        <div class="d-flex justify-content-center gap-3 flex-wrap">
                            <a href="/contact" class="btn btn-primary btn-lg px-5">Contact Us</a>
                            <a href="/products" class="btn btn-outline-light btn-lg px-5">View Products</a>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="page_about_record" model="website.page">
        <field name="name">About</field>
        <field name="url">/about</field>
        <field name="view_id" ref="page_about"/>
        <field name="website_published">True</field>
    </record>
</odoo>
