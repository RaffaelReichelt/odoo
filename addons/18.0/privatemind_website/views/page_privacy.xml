<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="page_privacy" name="PrivateMind Privacy Policy">
        <t t-call="website.layout">
            <div id="wrap">

                <!-- Hero -->
                <section style="background:linear-gradient(135deg,#0a0f1e 0%,#0d1b3e 50%,#0a0f1e 100%);padding:60px 0 48px;border-bottom:1px solid rgba(255,255,255,0.08);">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <p style="color:#6c9fff;font-size:0.82rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;">Legal</p>
                                <h1 style="color:#fff;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;line-height:1.2;margin-bottom:16px;">
                                    Privacy Policy
                                </h1>
                                <p style="color:rgba(255,255,255,0.6);font-size:1rem;margin:0;">
                                    Last updated: January 2026
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Content -->
                <section style="padding:64px 0 80px;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">

                                <!-- Intro note -->
                                <div class="mb-5 p-4 rounded" style="background:#f0f7ff;border-left:4px solid #0052cc;">
                                    <p style="margin:0;color:#0052cc;font-size:0.9rem;">
                                        <strong>In brief:</strong> PrivateMind processes your data exclusively on its own servers in Germany. We do not share personal data with third parties and do not use cloud-based AI services. This page fully describes what data we collect and how we process it.
                                    </p>
                                </div>

                                <!-- 1 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">1. Data Controller</h2>
                                <p>The controller within the meaning of the General Data Protection Regulation (GDPR) is:</p>
                                <address style="font-style:normal;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:20px;margin-bottom:16px;">
                                    <strong>PrivateMind GmbH (in formation)</strong><br/>
                                    Raffael Reichelt<br/>
                                    Dresden, Saxony · Germany<br/>
                                    <br/>
                                    Email: <a href="mailto:info@privatemind.eu">info@privatemind.eu</a><br/>
                                    Phone: <a href="tel:+4935148271891">+49 351 48271891</a><br/>
                                    Web: <a href="https://privatemind.eu">privatemind.eu</a>
                                </address>

                                <!-- 2 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">2. Collection and Processing of Personal Data</h2>

                                <h3 style="font-size:1rem;font-weight:700;color:#0a0f1e;margin:24px 0 10px;">2.1 Server Logs</h3>
                                <p>When you visit our website, technical access data is automatically stored in server log files. This includes:</p>
                                <ul>
                                    <li>IP address (anonymised after 7 days)</li>
                                    <li>Date and time of access</li>
                                    <li>URL accessed</li>
                                    <li>Volume of data transferred</li>
                                    <li>Browser type and operating system</li>
                                </ul>
                                <p>Legal basis: Art. 6(1)(f) GDPR (legitimate interest in the operation and security of the website). Log files are automatically deleted after 30 days.</p>

                                <h3 style="font-size:1rem;font-weight:700;color:#0a0f1e;margin:24px 0 10px;">2.2 Contact Form</h3>
                                <p>When you use our contact form, we process the data you provide (name, email address, company name, message) in order to handle your enquiry.</p>
                                <p>Legal basis: Art. 6(1)(b) GDPR (pre-contractual measures) or Art. 6(1)(f) GDPR (legitimate interest in responding to enquiries).</p>
                                <p>Your data is stored on our own Odoo server in Germany and is not shared with third parties. Enquiries that do not result in a contract are deleted after 24 months.</p>

                                <h3 style="font-size:1rem;font-weight:700;color:#0a0f1e;margin:24px 0 10px;">2.3 No Cookies / No Tracking</h3>
                                <p>This website does not use tracking cookies, analytics tools (e.g. Google Analytics), or social media tracking. Only technically necessary session cookies are used; these are deleted when you close your browser.</p>

                                <!-- 3 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">3. Disclosure to Third Parties</h2>
                                <p>Your personal data will <strong>not</strong> be disclosed to third parties unless:</p>
                                <ul>
                                    <li>you have given your explicit consent (Art. 6(1)(a) GDPR), or</li>
                                    <li>disclosure is necessary for the performance of a contract (Art. 6(1)(b) GDPR), or</li>
                                    <li>we are legally obliged to do so (Art. 6(1)(c) GDPR).</li>
                                </ul>
                                <p>We do not use US-based cloud services. All data remains on servers located in Germany.</p>

                                <!-- 4 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">4. Data Security</h2>
                                <p>Our website is transmitted exclusively over HTTPS (TLS 1.3). Our servers are located in a German data centre and are protected by firewalls, access controls, and regular security updates. As a provider of AI appliances, we treat data security as a core competency.</p>

                                <!-- 5 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">5. Your Rights as a Data Subject</h2>
                                <p>Under the GDPR you have the following rights against us:</p>
                                <div class="row g-3 my-2">
                                    <div class="col-md-6">
                                        <div class="p-3 rounded h-100" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                            <strong style="color:#0a0f1e;">Access</strong> <span style="color:#6c757d;font-size:0.8rem;">Art. 15 GDPR</span>
                                            <p style="font-size:0.88rem;color:#4a5d73;margin:6px 0 0;">You may request information about the data we store about you.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="p-3 rounded h-100" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                            <strong style="color:#0a0f1e;">Rectification</strong> <span style="color:#6c757d;font-size:0.8rem;">Art. 16 GDPR</span>
                                            <p style="font-size:0.88rem;color:#4a5d73;margin:6px 0 0;">You may request the correction of inaccurate data.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="p-3 rounded h-100" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                            <strong style="color:#0a0f1e;">Erasure</strong> <span style="color:#6c757d;font-size:0.8rem;">Art. 17 GDPR</span>
                                            <p style="font-size:0.88rem;color:#4a5d73;margin:6px 0 0;">You may request the deletion of your data, provided no statutory retention obligations apply.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="p-3 rounded h-100" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                            <strong style="color:#0a0f1e;">Restriction</strong> <span style="color:#6c757d;font-size:0.8rem;">Art. 18 GDPR</span>
                                            <p style="font-size:0.88rem;color:#4a5d73;margin:6px 0 0;">You may request that processing of your data be restricted.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="p-3 rounded h-100" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                            <strong style="color:#0a0f1e;">Portability</strong> <span style="color:#6c757d;font-size:0.8rem;">Art. 20 GDPR</span>
                                            <p style="font-size:0.88rem;color:#4a5d73;margin:6px 0 0;">You may receive your data in a structured, machine-readable format.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="p-3 rounded h-100" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                            <strong style="color:#0a0f1e;">Objection</strong> <span style="color:#6c757d;font-size:0.8rem;">Art. 21 GDPR</span>
                                            <p style="font-size:0.88rem;color:#4a5d73;margin:6px 0 0;">You may object to the processing of your data on the basis of legitimate interests.</p>
                                        </div>
                                    </div>
                                </div>
                                <p class="mt-3">To exercise your rights, please contact: <a href="mailto:info@privatemind.eu">info@privatemind.eu</a></p>

                                <!-- 6 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">6. Right to Lodge a Complaint</h2>
                                <p>You have the right to lodge a complaint with the competent data protection supervisory authority. The authority responsible for Saxony is:</p>
                                <address style="font-style:normal;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:20px;">
                                    <strong>Saxon Data Protection Commissioner</strong><br/>
                                    Devrientstraße 5<br/>
                                    01067 Dresden<br/>
                                    <a href="https://www.saechsdsb.de">www.saechsdsb.de</a>
                                </address>

                                <!-- 7 -->
                                <h2 style="font-size:1.25rem;font-weight:700;color:#0a0f1e;margin:40px 0 16px;padding-bottom:8px;border-bottom:2px solid #e2e8f0;">7. Currency of This Policy</h2>
                                <p>This privacy policy is current as of January 2026. We reserve the right to update it to reflect changes in legal requirements or our services. The current version is always available at <a href="/privacy">privatemind.eu/privacy</a>.</p>

                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <record id="page_privacy_record" model="website.page">
        <field name="name">Privacy Policy</field>
        <field name="url">/privacy</field>
        <field name="view_id" ref="page_privacy"/>
        <field name="website_published">True</field>
    </record>

</odoo>
