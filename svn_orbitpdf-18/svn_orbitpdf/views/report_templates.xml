<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template inherit_id="web.report_layout" id="ob_report_layout">
        <xpath expr="//title" position="after">
            <base t-if="ob_url" t-att-href="ob_url"/>
        </xpath>
        <xpath expr="//t[@t-call-assets='web.report_assets_common']" position="replace">
            <t t-if="ob_assets_pdf">
                <t t-call-assets="web.report_assets_pdf" t-js="false"/>
                <t t-call-assets="web.report_assets_common" t-js="false"/>
            </t>
            <t t-else="" t-call-assets="web.report_assets_common"/>
        </xpath>
        <xpath expr="//head" position="inside">
            <style t-if="ob_css" t-out="ob_css"/>
        </xpath>
    </template>
</odoo>
